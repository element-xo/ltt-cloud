# ----------------------------------------------------------
# .env.example -- TEMPLATE ONLY, never commit real secrets
# Copy to .env and fill in actual values locally.
#
# These keys must match ltt_core.config.Settings fields.
# In CI:  store values in GitHub Actions Secrets.
# In K8s: store values in a Kubernetes Secret object.
# ----------------------------------------------------------

# REQUIRED -- sensitive
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://HOST:6379/0
JWT_SECRET_KEY=<your-jwt-signing-key-min-32-chars>

# REQUIRED -- non-sensitive
ENVIRONMENT=dev

# OPTIONAL -- non-sensitive (have safe defaults in Settings)
BRIGHTWAY_PROJECT=LTT_P2X
API_URL=http://localhost:8000

# Docker-compose also reads these for the postgres container:
POSTGRES_USER=<your_db_user>
POSTGRES_PASSWORD=<your_db_password>
POSTGRES_DB=<your_db_name>
FROM python:3.12-slim

# Install dev tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    vim \
    && rm -rf /var/lib/apt/lists/*

# Install Python dev dependencies
COPY pyproject.toml .
RUN pip install --no-cache-dir -e .[dev]

# Create non-root user
RUN useradd -m vscode
USER vscode

WORKDIR /workspace